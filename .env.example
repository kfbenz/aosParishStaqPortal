# ParishStaq Portal Configuration
# Copy this to .env and customize

# App settings
APP_NAME="ParishStaq Portal"
DEBUG=false

# IMPORTANT: Generate a new secret key for production!
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database URL
# SQLite: sqlite:///portal.db
# MariaDB: mysql+pymysql://user:password@localhost/portal_app
DATABASE_URL=mysql+pymysql://portal:password@localhost/portal_app

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# 2FA settings
TOTP_ISSUER=ParishStaq Portal
REQUIRE_2FA=true
